# ─── Dependencies ───────────────────────────────────────────
node_modules/

# ─── Expo / React Native (apps/*) ───────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Native projects are generated by `expo prebuild`; keep them out of VCS.
apps/*/ios/
apps/*/android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ─── firmware (ESP32 / PlatformIO — #35) ────────────────────
.pio/

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── Environment / secrets ──────────────────────────────────
.env
.env*.local

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# ─── Editor / OS ────────────────────────────────────────────
.DS_Store
*.pem
.idea/
.vscode/
