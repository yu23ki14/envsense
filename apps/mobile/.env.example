# Copy to .env.local and fill in. Expo inlines EXPO_PUBLIC_* vars at build time.

# Groq API key — required for the Whisper transcription pipeline (#38).
EXPO_PUBLIC_GROQ_API_KEY=

# Used by later migrations (#39 image LLM / #40 agent).
EXPO_PUBLIC_OLLAMA_API_URL=http://localhost:11434/api/chat
EXPO_PUBLIC_OPENAI_API_KEY=
